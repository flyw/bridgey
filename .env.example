# Bridgey Configuration Template
# Copy this file to .env and fill in your values

# Common Authentication Token (Web client and Agent must match)
BRIDGE_TOKEN=secret_bridgey_token_123

# Relay Server Settings (0.0.0.0 means listen on all interfaces)
RELAY_HOST=0.0.0.0
RELAY_PORT=3000

# Agent Settings (Replace with your VPS public IP in production)
RELAY_URL=http://0.0.0.0:3000
